---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
---

<Layout title="NEXUS 2026 - The Future of Technology">
  <Navigation />
  
  <main>
    <section id="hero" class="hero">
      <div class="hero-bg"></div>
      <div class="container hero-container">
        <div class="hero-content">
          <span class="hero-badge">June 15-16, 2026 • San Francisco</span>
          <h1 class="hero-title">
            <span class="title-line">Where</span>
            <span class="title-line">Innovation</span>
            <span class="title-line">Meets</span>
            <span class="title-line title-accent">Tomorrow</span>
          </h1>
          <p class="hero-subtitle">
            Join 2,000+ visionaries, innovators, and industry leaders at the premier technology conference shaping the future.
          </p>
          <div class="hero-cta">
            <a href="#cta" class="btn btn-primary btn-lg">Reserve Your Spot</a>
            <a href="#about" class="btn btn-secondary btn-lg">Learn More</a>
          </div>
          <div class="hero-stats">
            <div class="stat">
              <span class="stat-number">50+</span>
              <span class="stat-label">Speakers</span>
            </div>
            <div class="stat">
              <span class="stat-number">2</span>
              <span class="stat-label">Days</span>
            </div>
            <div class="stat">
              <span class="stat-number">20+</span>
              <span class="stat-label">Workshops</span>
            </div>
          </div>
        </div>
      </div>
    </section>
    
    <section id="about" class="about">
      <div class="container">
        <div class="about-content reveal-up">
          <h2>Redefining What's Possible</h2>
          <p class="about-lead">
            NEXUS 2026 brings together the brightest minds in technology for two days of groundbreaking insights, hands-on workshops, and unparalleled networking.
          </p>
          <div class="about-grid">
            <div class="about-card reveal-up">
              <div class="card-icon">🚀</div>
              <h3>Innovation</h3>
              <p>Discover cutting-edge technologies transforming industries from AI to quantum computing.</p>
            </div>
            <div class="about-card reveal-up" style="animation-delay: 100ms;">
              <div class="card-icon">💡</div>
              <h3>Inspiration</h3>
              <p>Hear from visionaries shaping the future and learn from their journeys.</p>
            </div>
            <div class="about-card reveal-up" style="animation-delay: 200ms;">
              <div class="card-icon">🤝</div>
              <h3>Connection</h3>
              <p>Build lasting relationships with peers, mentors, and potential collaborators.</p>
            </div>
          </div>
        </div>
      </div>
    </section>
    
    <section id="speakers" class="speakers">
      <div class="container">
        <div class="section-header reveal-up">
          <h2>Featured Speakers</h2>
          <p>Learn from industry leaders and pioneers</p>
        </div>
        <div class="speakers-grid">
          <article class="speaker-card reveal-up">
            <div class="speaker-image">
              <div class="speaker-placeholder">ER</div>
            </div>
            <div class="speaker-info">
              <h3>Dr. Elena Rodriguez</h3>
              <p class="speaker-role">AI Research Director</p>
              <p class="speaker-company">NeuralTech Labs</p>
            </div>
          </article>
          <article class="speaker-card reveal-up" style="animation-delay: 100ms;">
            <div class="speaker-image">
              <div class="speaker-placeholder">MC</div>
            </div>
            <div class="speaker-info">
              <h3>Marcus Chen</h3>
              <p class="speaker-role">Founder & CEO</p>
              <p class="speaker-company">Quantum Dynamics</p>
            </div>
          </article>
          <article class="speaker-card reveal-up" style="animation-delay: 200ms;">
            <div class="speaker-image">
              <div class="speaker-placeholder">SW</div>
            </div>
            <div class="speaker-info">
              <h3>Sarah Williams</h3>
              <p class="speaker-role">VP of Engineering</p>
              <p class="speaker-company">CloudScale Inc</p>
            </div>
          </article>
          <article class="speaker-card reveal-up" style="animation-delay: 300ms;">
            <div class="speaker-image">
              <div class="speaker-placeholder">JO</div>
            </div>
            <div class="speaker-info">
              <h3>Dr. James Okonkwo</h3>
              <p class="speaker-role">Chief Innovation Officer</p>
              <p class="speaker-company">FutureTech Ventures</p>
            </div>
          </article>
          <article class="speaker-card reveal-up" style="animation-delay: 400ms;">
            <div class="speaker-image">
              <div class="speaker-placeholder">AP</div>
            </div>
            <div class="speaker-info">
              <h3>Aisha Patel</h3>
              <p class="speaker-role">Head of Product</p>
              <p class="speaker-company">NeuroLink</p>
            </div>
          </article>
          <article class="speaker-card reveal-up" style="animation-delay: 500ms;">
            <div class="speaker-image">
              <div class="speaker-placeholder">CM</div>
            </div>
            <div class="speaker-info">
              <h3>Carlos Mendez</h3>
              <p class="speaker-role">Security Architect</p>
              <p class="speaker-company">CyberShield</p>
            </div>
          </article>
        </div>
      </div>
    </section>
    
    <section id="schedule" class="schedule">
      <div class="container">
        <div class="section-header reveal-up">
          <h2>Event Schedule</h2>
          <p>Two days of transformative content</p>
        </div>
        <div class="schedule-tabs reveal-up">
          <button class="tab-btn active" data-day="day1">Day 1 - June 15</button>
          <button class="tab-btn" data-day="day2">Day 2 - June 16</button>
        </div>
        <div class="schedule-content">
          <div class="day-schedule active" id="day1">
            <div class="session reveal-up">
              <div class="session-time">08:00</div>
              <div class="session-info">
                <h4>Registration & Welcome Coffee</h4>
                <p>Check-in, grab your badge, and network with fellow attendees.</p>
              </div>
            </div>
            <div class="session reveal-up">
              <div class="session-time">09:00</div>
              <div class="session-info">
                <h4>Opening Keynote: The Future is Now</h4>
                <p class="session-speaker">Dr. Elena Rodriguez</p>
                <p>Exploring how AI is reshaping every industry.</p>
              </div>
            </div>
            <div class="session reveal-up">
              <div class="session-time">11:00</div>
              <div class="session-info">
                <h4>Quantum Computing: From Theory to Practice</h4>
                <p class="session-speaker">Marcus Chen</p>
                <p>Real-world quantum computing applications.</p>
              </div>
            </div>
            <div class="session reveal-up">
              <div class="session-time">14:00</div>
              <div class="session-info">
                <h4>Building for Scale: Cloud Architecture Masterclass</h4>
                <p class="session-speaker">Sarah Williams</p>
                <p>Battle-tested patterns for resilient systems.</p>
              </div>
            </div>
          </div>
          <div class="day-schedule" id="day2">
            <div class="session reveal-up">
              <div class="session-time">09:00</div>
              <div class="session-info">
                <h4>Human-Centered Design in the AI Era</h4>
                <p class="session-speaker">Aisha Patel</p>
                <p>Maintaining humanity in an automated world.</p>
              </div>
            </div>
            <div class="session reveal-up">
              <div class="session-time">11:00</div>
              <div class="session-info">
                <h4>Zero Trust Security for AI Systems</h4>
                <p class="session-speaker">Carlos Mendez</p>
                <p>Framework for securing AI-powered infrastructure.</p>
              </div>
            </div>
            <div class="session reveal-up">
              <div class="session-time">14:00</div>
              <div class="session-info">
                <h4>Workshop: Hands-on AI Prototyping</h4>
                <p class="session-speaker">Dr. Elena Rodriguez</p>
                <p>Build your first AI prototype.</p>
              </div>
            </div>
            <div class="session reveal-up">
              <div class="session-time">17:00</div>
              <div class="session-info">
                <h4>Closing Ceremony & Awards</h4>
                <p>Official closing and awards presentation.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
    
    <section id="cta" class="cta">
      <div class="container">
        <div class="cta-content reveal-up">
          <h2>Ready to Shape the Future?</h2>
          <p>Join us at NEXUS 2026 and be part of the conversation defining tomorrow's technology.</p>
          <div class="cta-pricing">
            <div class="pricing-card">
              <h3>Early Bird</h3>
              <div class="price"><span class="currency">$</span>299</div>
              <ul class="pricing-features">
                <li>Full conference access</li>
                <li>Workshop participation</li>
                <li>Networking events</li>
                <li>Conference swag</li>
              </ul>
              <button class="btn btn-primary">Register Now</button>
            </div>
            <div class="pricing-card featured">
              <span class="popular-badge">Most Popular</span>
              <h3>Professional</h3>
              <div class="price"><span class="currency">$</span>499</div>
              <ul class="pricing-features">
                <li>Full conference access</li>
                <li>All workshops</li>
                <li>VIP networking</li>
                <li>Premium swag</li>
                <li>1-on-1 mentoring</li>
              </ul>
              <button class="btn btn-primary">Register Now</button>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
  
  <footer class="footer">
    <div class="container">
      <div class="footer-grid">
        <div class="footer-brand">
          <span class="logo-text">NEXUS</span>
          <span class="logo-year">2026</span>
          <p>The premier technology conference for innovators and visionaries.</p>
        </div>
        <div class="footer-links">
          <h4>Quick Links</h4>
          <ul>
            <li><a href="#about">About</a></li>
            <li><a href="#speakers">Speakers</a></li>
            <li><a href="#schedule">Schedule</a></li>
            <li><a href="#cta">Register</a></li>
          </ul>
        </div>
        <div class="footer-links">
          <h4>Resources</h4>
          <ul>
            <li><a href="#">FAQ</a></li>
            <li><a href="#">Venue</a></li>
            <li><a href="#">Travel</a></li>
            <li><a href="#">Contact</a></li>
          </ul>
        </div>
        <div class="footer-social">
          <h4>Follow Us</h4>
          <div class="social-links">
            <a href="#" aria-label="Twitter">𝕏</a>
            <a href="#" aria-label="LinkedIn">in</a>
            <a href="#" aria-label="Instagram">📷</a>
          </div>
        </div>
      </div>
      <div class="footer-bottom">
        <p>&copy; 2026 NEXUS Conference. All rights reserved.</p>
      </div>
    </div>
  </footer>
</Layout>

<style>
  /* Hero Section */
  .hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    position: relative;
    overflow: hidden;
    padding-top: 90px;
  }
  
  .hero-bg {
    position: absolute;
    inset: 0;
    background: 
      radial-gradient(ellipse 80% 50% at 50% -20%, rgba(99, 102, 241, 0.3), transparent),
      radial-gradient(ellipse 60% 40% at 80% 60%, rgba(16, 185, 129, 0.15), transparent),
      radial-gradient(ellipse 50% 30% at 20% 80%, rgba(245, 158, 11, 0.1), transparent);
    z-index: -1;
  }
  
  .hero-container {
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
  }
  
  .hero-content {
    max-width: 900px;
  }
  
  .hero-badge {
    display: inline-block;
    padding: var(--space-2) var(--space-4);
    background: rgba(99, 102, 241, 0.15);
    border: 1px solid rgba(99, 102, 241, 0.3);
    border-radius: var(--radius-full);
    font-size: var(--text-sm);
    font-weight: var(--font-weight-medium);
    color: var(--color-primary-light);
    margin-bottom: var(--space-8);
    margin-top: var(--space-4);
  }
  
  .hero-title {
    font-size: clamp(2.5rem, 8vw, 5rem);
    line-height: 1.1;
    margin-bottom: var(--space-6);
  }
  
  .title-line {
    display: block;
  }
  
  .title-accent {
    background: linear-gradient(135deg, var(--color-primary-light), var(--color-secondary));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  
  .hero-subtitle {
    font-size: var(--text-xl);
    color: var(--color-text-secondary);
    max-width: 600px;
    margin: 0 auto var(--space-8);
  }
  
  .hero-cta {
    display: flex;
    gap: var(--space-4);
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: var(--space-12);
  }
  
  .btn-lg {
    padding: var(--space-4) var(--space-8);
    font-size: var(--text-lg);
  }
  
  .hero-stats {
    display: flex;
    gap: var(--space-12);
    justify-content: center;
  }
  
  .stat {
    text-align: center;
  }
  
  .stat-number {
    display: block;
    font-size: var(--text-4xl);
    font-weight: var(--font-weight-bold);
    color: var(--color-text-primary);
  }
  
  .stat-label {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }
  
  /* About Section */
  .about {
    background: var(--color-bg-secondary);
  }
  
  .about-content {
    text-align: center;
  }
  
  .about-content h2 {
    margin-bottom: var(--space-6);
  }
  
  .about-lead {
    font-size: var(--text-xl);
    color: var(--color-text-secondary);
    max-width: 700px;
    margin: 0 auto var(--space-12);
  }
  
  .about-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--space-8);
  }
  
  .about-card {
    padding: var(--space-8);
    background: var(--color-bg-card);
    border-radius: var(--radius-xl);
    border: 1px solid var(--color-border);
    text-align: left;
  }
  
  .card-icon {
    font-size: 2.5rem;
    margin-bottom: var(--space-4);
  }
  
  .about-card h3 {
    margin-bottom: var(--space-2);
  }
  
  .about-card p {
    margin-bottom: 0;
  }
  
  /* Speakers Section */
  .speakers {
    background: var(--color-bg-primary);
  }
  
  .section-header {
    text-align: center;
    margin-bottom: var(--space-12);
  }
  
  .section-header p {
    font-size: var(--text-lg);
    margin-top: var(--space-2);
  }
  
  .speakers-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: var(--space-6);
  }
  
  .speaker-card {
    background: var(--color-bg-card);
    border-radius: var(--radius-xl);
    overflow: hidden;
    border: 1px solid var(--color-border);
    transition: transform var(--transition-base), box-shadow var(--transition-base);
  }
  
  .speaker-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-xl);
  }
  
  .speaker-image {
    aspect-ratio: 16/10;
    background: linear-gradient(135deg, var(--color-bg-secondary), var(--color-bg-elevated));
    display: flex;
    align-items: center;
    justify-content: center;
  }
  
  .speaker-placeholder {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--color-primary), var(--color-primary-dark));
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: var(--text-xl);
    font-weight: var(--font-weight-bold);
    color: white;
  }
  
  .speaker-info {
    padding: var(--space-6);
  }
  
  .speaker-info h3 {
    font-size: var(--text-lg);
    margin-bottom: var(--space-1);
  }
  
  .speaker-role {
    color: var(--color-primary-light);
    font-size: var(--text-sm);
    margin-bottom: var(--space-1);
  }
  
  .speaker-company {
    color: var(--color-text-muted);
    font-size: var(--text-sm);
    margin-bottom: 0;
  }
  
  /* Schedule Section */
  .schedule {
    background: var(--color-bg-secondary);
  }
  
  .schedule-tabs {
    display: flex;
    justify-content: center;
    gap: var(--space-4);
    margin-bottom: var(--space-8);
  }
  
  .tab-btn {
    padding: var(--space-3) var(--space-6);
    background: transparent;
    border: 2px solid var(--color-border);
    border-radius: var(--radius-lg);
    color: var(--color-text-secondary);
    font-size: var(--text-base);
    font-weight: var(--font-weight-medium);
    cursor: pointer;
    transition: all var(--transition-fast);
  }
  
  .tab-btn:hover {
    border-color: var(--color-primary);
    color: var(--color-text-primary);
  }
  
  .tab-btn.active {
    background: var(--color-primary);
    border-color: var(--color-primary);
    color: white;
  }
  
  .day-schedule {
    display: none;
  }
  
  .day-schedule.active {
    display: block;
  }
  
  .session {
    display: flex;
    gap: var(--space-6);
    padding: var(--space-6);
    background: var(--color-bg-card);
    border-radius: var(--radius-lg);
    margin-bottom: var(--space-4);
    border: 1px solid var(--color-border);
  }
  
  .session-time {
    flex-shrink: 0;
    width: 80px;
    font-size: var(--text-lg);
    font-weight: var(--font-weight-bold);
    color: var(--color-primary-light);
  }
  
  .session-info h4 {
    font-size: var(--text-lg);
    margin-bottom: var(--space-1);
  }
  
  .session-speaker {
    color: var(--color-primary-light);
    font-size: var(--text-sm);
    margin-bottom: var(--space-1);
  }
  
  .session-info p:last-child {
    margin-bottom: 0;
  }
  
  /* CTA Section */
  .cta {
    background: var(--color-bg-primary);
    text-align: center;
  }
  
  .cta-content h2 {
    margin-bottom: var(--space-4);
  }
  
  .cta-content > p {
    font-size: var(--text-lg);
    max-width: 600px;
    margin: 0 auto var(--space-10);
  }
  
  .cta-pricing {
    display: flex;
    justify-content: center;
    gap: var(--space-6);
    flex-wrap: wrap;
  }
  
  .pricing-card {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    padding: var(--space-8);
    width: 320px;
    position: relative;
  }
  
  .pricing-card.featured {
    border-color: var(--color-primary);
    box-shadow: var(--shadow-glow);
  }
  
  .popular-badge {
    position: absolute;
    top: -12px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--color-primary);
    color: white;
    padding: var(--space-1) var(--space-4);
    border-radius: var(--radius-full);
    font-size: var(--text-xs);
    font-weight: var(--font-weight-medium);
    text-transform: uppercase;
  }
  
  .pricing-card h3 {
    font-size: var(--text-xl);
    margin-bottom: var(--space-2);
  }
  
  .price {
    font-size: var(--text-5xl);
    font-weight: var(--font-weight-bold);
    color: var(--color-text-primary);
    margin-bottom: var(--space-6);
  }
  
  .currency {
    font-size: var(--text-2xl);
    vertical-align: super;
  }
  
  .pricing-features {
    list-style: none;
    margin-bottom: var(--space-6);
    text-align: left;
  }
  
  .pricing-features li {
    padding: var(--space-2) 0;
    color: var(--color-text-secondary);
    border-bottom: 1px solid var(--color-border);
  }
  
  .pricing-features li:last-child {
    border-bottom: none;
  }
  
  /* Footer */
  .footer {
    background: var(--color-bg-secondary);
    padding: var(--space-16) 0 var(--space-8);
    border-top: 1px solid var(--color-border);
    overflow-x: hidden;
  }
  
  .footer-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: var(--space-8);
    margin-bottom: var(--space-12);
    width: 100%;
  }
  
  .footer-brand .logo-text {
    font-size: var(--text-2xl);
    font-weight: var(--font-weight-bold);
    color: var(--color-text-primary);
    letter-spacing: 0.1em;
  }
  
  .footer-brand .logo-year {
    font-size: var(--text-lg);
    color: var(--color-primary-light);
  }
  
  .footer-brand p {
    margin-top: var(--space-4);
    font-size: var(--text-sm);
  }
  
  .footer-links h4 {
    font-size: var(--text-sm);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: var(--space-4);
    color: var(--color-text-primary);
  }
  
  .footer-links ul {
    list-style: none;
  }
  
  .footer-links li {
    margin-bottom: var(--space-2);
  }
  
  .footer-links a {
    color: var(--color-text-secondary);
    font-size: var(--text-sm);
    text-decoration: none;
  }
  
  .footer-links a:hover {
    color: var(--color-primary-light);
  }
  
  .footer-social {
    width: 100%;
  }
  
  .social-links {
    display: flex;
    gap: var(--space-4);
  }
  
  .social-links a {
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-bg-card);
    border-radius: 50%;
    color: var(--color-text-secondary);
    text-decoration: none;
    transition: all var(--transition-fast);
  }
  
  .social-links a:hover {
    background: var(--color-primary);
    color: white;
  }
  
  .footer-bottom {
    text-align: center;
    padding-top: var(--space-8);
    border-top: 1px solid var(--color-border);
  }
  
  .footer-bottom p {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin-bottom: 0;
  }
  
  @media (max-width: var(--breakpoint-lg)) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
    }
    
    .footer-brand {
      grid-column: span 2;
    }
  }
  
  @media (max-width: var(--breakpoint-md)) {
    .footer-grid {
      grid-template-columns: 1fr;
    }
    
    .footer-brand {
